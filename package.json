{
  "name": "customers-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --forceExit --coverage",
    "cypress": "cypress open",
    "cypress:run": "cypress run",
    "generate:types": "npx openapi-typescript http://localhost:8000/openapi.json -o src/lib/types/estate-os-api.ts && npx openapi-typescript http://localhost:9000/openapi.json -o src/lib/types/applicants-intake-service-api.ts && curl -s http://localhost:6000/openapi.json -o /tmp/contract-intelligence-openapi.json && npx openapi-typescript /tmp/contract-intelligence-openapi.json -o src/lib/types/contract-intelligence-service-api.ts",
    "generate:types:estate-os": "npx openapi-typescript http://localhost:8000/openapi.json -o src/lib/types/estate-os-api.ts",
    "generate:types:applicants": "npx openapi-typescript http://localhost:9000/openapi.json -o src/lib/types/applicants-intake-service-api.ts",
    "generate:types:contracts": "curl -s http://localhost:6000/openapi.json -o /tmp/contract-intelligence-openapi.json && npx openapi-typescript /tmp/contract-intelligence-openapi.json -o src/lib/types/contract-intelligence-service-api.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "resend": "^4.0.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cypress": "^15.11.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-storybook": "^10.3.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.12.10",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "undici": "^7.24.4",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
